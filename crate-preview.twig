{# ============================================================ #}
{#                     CRATE DEFINITIONS                        #}
{# ============================================================ #}

{#
    Include this component once in your layout:
        {% include 'components/crate-preview.twig' %}

    Then anywhere in your page content, write:
        @crate-preview-builder:epic
        @crate-preview-builder:starter
        @crate-preview-builder:legendary

    Each crate supports:
        theme         'minecraft' or 'sleek'
        empty_slot    null or item name e.g. "dirt"

    Colour overrides (null = use theme default):
        color_bg_panel, color_bg_cell, color_bg_cell_hover,
        color_bg_tooltip, color_text_tooltip, color_border_cell,
        color_border_tooltip, color_text_count

    Item attributes:
        @name="..."        Display name (required)
        @item="..."        Item ID for API: diamond_sword
        @img="..."         Custom image URL (overrides @item)
        @quantity="<int>"  Stack count shown bottom-right
        @lore="..."        Italic lore lines in tooltip
        @description="..."  Description shown below lore
        @enchanted         Adds ?glint=true to image URL
    Use \n inside any value for line breaks
#}

{% set crates = {

    epic: {
        theme:                'minecraft',
        empty_slot:           null,
        color_bg_panel:       null,
        color_bg_cell:        null,
        color_bg_cell_hover:  null,
        color_bg_tooltip:     null,
        color_text_tooltip:   null,
        color_border_cell:    null,
        color_border_tooltip: null,
        color_text_count:     null,
        items: "
@name=\"Diamond Sword\"@item=\"diamond_sword\"@quantity=\"1\"@lore=\"Sharpness V\\nUnbreaking III\"@description=\"A finely crafted blade.\"@enchanted
@name=\"Diamond\"@item=\"diamond\"@quantity=\"23\"@lore=\"Precious gem\"
@name=\"Iron Ingot\"@item=\"iron_ingot\"@quantity=\"64\"
@name=\"Apple\"@item=\"apple\"@quantity=\"5\"@lore=\"Restores 4 hunger\"@description=\"A crisp red apple.\"
@name=\"Bow\"@item=\"bow\"@quantity=\"1\"@lore=\"Power IV\\nFlame I\"@enchanted
@name=\"Arrow\"@item=\"arrow\"@quantity=\"32\"
@name=\"Torch\"@item=\"torch\"@quantity=\"18\"@description=\"Keeps the dark at bay.\"
@name=\"Cooked Beef\"@item=\"cooked_beef\"@quantity=\"8\"@lore=\"Restores 8 hunger\"
@name=\"Enchanted Book\"@item=\"enchanted_book\"@quantity=\"2\"@lore=\"Fortune III\"@description=\"Stores a powerful enchantment.\"@enchanted
@name=\"Ender Pearl\"@item=\"ender_pearl\"@quantity=\"7\"@lore=\"Teleports on throw\"
@name=\"Gold Ingot\"@item=\"gold_ingot\"@quantity=\"12\"
@name=\"Redstone\"@item=\"redstone\"@quantity=\"64\"@description=\"Used in redstone circuits.\"
@name=\"Emerald\"@item=\"emerald\"@quantity=\"3\"@lore=\"Currency of villagers\"
@name=\"Gravel\"@item=\"gravel\"@quantity=\"64\"
@name=\"Bone\"@item=\"bone\"@quantity=\"9\"@lore=\"Can tame wolves\"
        "
    },

    starter: {
        theme:                'sleek',
        empty_slot:           'dirt',
        color_bg_panel:       null,
        color_bg_cell:        null,
        color_bg_cell_hover:  null,
        color_bg_tooltip:     null,
        color_text_tooltip:   null,
        color_border_cell:    null,
        color_border_tooltip: null,
        color_text_count:     null,
        items: "
@name=\"Wooden Sword\"@item=\"wooden_sword\"@quantity=\"1\"@lore=\"A beginner's blade\"
@name=\"Bread\"@item=\"bread\"@quantity=\"10\"@lore=\"Restores 5 hunger\"
@name=\"Oak Log\"@item=\"oak_log\"@quantity=\"32\"
@name=\"Cobblestone\"@item=\"cobblestone\"@quantity=\"64\"
@name=\"Crafting Table\"@item=\"crafting_table\"@quantity=\"1\"@description=\"Essential for survival.\"
@name=\"Furnace\"@item=\"furnace\"@quantity=\"1\"
@name=\"Wooden Pickaxe\"@item=\"wooden_pickaxe\"@quantity=\"1\"@lore=\"Mine your first ores\"
        "
    },

    legendary: {
        theme:                'sleek',
        empty_slot:           null,
        color_bg_panel:       '#1a0a2e',
        color_bg_cell:        '#0d0520',
        color_bg_cell_hover:  '#2d1060',
        color_bg_tooltip:     '#1a0a2e',
        color_text_tooltip:   '#e8d5ff',
        color_border_cell:    '#6d28d9',
        color_border_tooltip: '#6d28d9',
        color_text_count:     '#c4b5fd',
        items: "
@name=\"Netherite Sword\"@item=\"netherite_sword\"@quantity=\"1\"@lore=\"Sharpness X\\nFire Aspect II\\nUnbreaking IV\"@description=\"The ultimate weapon.\"@enchanted
@name=\"Netherite Ingot\"@item=\"netherite_ingot\"@quantity=\"5\"@lore=\"Rare and powerful\"
@name=\"Totem of Undying\"@item=\"totem_of_undying\"@quantity=\"2\"@lore=\"Cheats death once\"@enchanted
@name=\"Elytra\"@item=\"elytra\"@quantity=\"1\"@lore=\"Soar through the skies\"@enchanted
@name=\"Beacon\"@item=\"beacon\"@quantity=\"1\"@lore=\"Grants powerful buffs\"@description=\"Place on a pyramid to activate.\"
@name=\"Nether Star\"@item=\"nether_star\"@quantity=\"3\"@lore=\"Drops from the Wither\"
@name=\"Dragon Egg\"@item=\"dragon_egg\"@quantity=\"1\"@lore=\"One of a kind\"@description=\"A trophy of your conquest.\"
        "
    },

} %}


{# ============================================================ #}
{#                     STYLES + JS                              #}
{# ============================================================ #}

<style>
    .inv-cell.item-slot { cursor: pointer; }
    .inv-cell.item-slot:hover .inv-tooltip { display: block !important; }
    .inv-item-img { image-rendering: pixelated; display: block; pointer-events: none; }
    .inv-item-img.empty-slot-img { opacity: 0.3; }
    .inv-count { position: absolute; bottom: 2px; right: 3px; line-height: 1; pointer-events: none; }
    .inv-tooltip { display: none; position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%); white-space: nowrap; z-index: 999; pointer-events: none; min-width: 120px; }
    .inv-tooltip-name  { display: block; white-space: nowrap; }
    .inv-tooltip-lore  { display: block; white-space: pre; font-style: italic; }
    .inv-tooltip-desc  { display: block; white-space: pre; }
</style>

<script>
(function () {

    const CRATES = {
        {% for name, c in crates %}
        {{ name }}: {
            theme:               {{ c.theme|json_encode|raw }},
            emptySlot:           {{ c.empty_slot ? c.empty_slot|json_encode|raw : 'null' }},
            colorBgPanel:        {{ c.color_bg_panel ? c.color_bg_panel|json_encode|raw : 'null' }},
            colorBgCell:         {{ c.color_bg_cell ? c.color_bg_cell|json_encode|raw : 'null' }},
            colorBgCellHover:    {{ c.color_bg_cell_hover ? c.color_bg_cell_hover|json_encode|raw : 'null' }},
            colorBgTooltip:      {{ c.color_bg_tooltip ? c.color_bg_tooltip|json_encode|raw : 'null' }},
            colorTextTooltip:    {{ c.color_text_tooltip ? c.color_text_tooltip|json_encode|raw : 'null' }},
            colorBorderCell:     {{ c.color_border_cell ? c.color_border_cell|json_encode|raw : 'null' }},
            colorBorderTooltip:  {{ c.color_border_tooltip ? c.color_border_tooltip|json_encode|raw : 'null' }},
            colorTextCount:      {{ c.color_text_count ? c.color_text_count|json_encode|raw : 'null' }},
            items:               {{ c.items|json_encode|raw }},
        },
        {% endfor %}
    };

    const THEMES = {
        minecraft: {
            fontUrl:            'https://fonts.googleapis.com/css2?family=VT323&display=swap',
            fontFamily:         "'VT323', monospace",
            panelBg:            '#c6c6c6',
            panelBorderTop:     '3px solid #ffffff',
            panelBorderLeft:    '3px solid #ffffff',
            panelBorderRight:   '3px solid #555555',
            panelBorderBottom:  '3px solid #555555',
            panelPadding:       '14px 16px 16px',
            panelShadow:        '3px 3px 0 #000, inset -1px -1px 0 #888, inset 1px 1px 0 #fff',
            panelRadius:        '0px',
            cellSize:           '40px',
            cellGap:            '4px',
            cellBg:             '#8b8b8b',
            cellHoverBg:        '#9f9f9f',
            cellHoverTransform: 'none',
            cellHoverShadow:    'none',
            cellBorderTop:      '2px solid #373737',
            cellBorderLeft:     '2px solid #373737',
            cellBorderRight:    '2px solid #ffffff',
            cellBorderBottom:   '2px solid #ffffff',
            cellRadius:         '0px',
            imgSize:            '28px',
            countSize:          '13px',
            countWeight:        '400',
            countColor:         '#ffffff',
            countShadow:        '1px 1px 0 #3f3f3f',
            tooltipBg:          '#100010',
            tooltipBorder:      '1px solid #2d0a63',
            tooltipText:        '#ffffff',
            tooltipLoreColor:   '#aa88ff',
            tooltipDescColor:   '#aaaaaa',
            tooltipSize:        '14px',
            tooltipWeight:      '400',
            tooltipPadding:     '6px 8px',
            tooltipTextShadow:  '1px 1px 0 #5a0060',
            tooltipShadow:      '2px 2px 0 #000',
            tooltipRadius:      '0px',
            tooltipTracking:    '0px',
            tooltipArrow:       '#2d0a63',
            itemsPerRow:        7,
        },
        sleek: {
            fontUrl:            'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap',
            fontFamily:         "'Inter', sans-serif",
            panelBg:            '#1e293b',
            panelBorderTop:     '1px solid #334155',
            panelBorderLeft:    '1px solid #334155',
            panelBorderRight:   '1px solid #334155',
            panelBorderBottom:  '1px solid #334155',
            panelPadding:       '20px',
            panelShadow:        '0 25px 50px rgba(0,0,0,0.6)',
            panelRadius:        '16px',
            cellSize:           '44px',
            cellGap:            '6px',
            cellBg:             '#0f172a',
            cellHoverBg:        '#1e3a5f',
            cellHoverTransform: 'scale(1.05)',
            cellHoverShadow:    '0 4px 12px rgba(0,0,0,0.4)',
            cellBorderTop:      '1px solid #334155',
            cellBorderLeft:     '1px solid #334155',
            cellBorderRight:    '1px solid #334155',
            cellBorderBottom:   '1px solid #334155',
            cellRadius:         '8px',
            imgSize:            '30px',
            countSize:          '11px',
            countWeight:        '600',
            countColor:         '#94a3b8',
            countShadow:        'none',
            tooltipBg:          '#1e293b',
            tooltipBorder:      '1px solid #475569',
            tooltipText:        '#f1f5f9',
            tooltipLoreColor:   '#a78bfa',
            tooltipDescColor:   '#64748b',
            tooltipSize:        '12px',
            tooltipWeight:      '500',
            tooltipPadding:     '8px 12px',
            tooltipTextShadow:  'none',
            tooltipShadow:      '0 8px 24px rgba(0,0,0,0.5)',
            tooltipRadius:      '6px',
            tooltipTracking:    '0.02em',
            tooltipArrow:       '#475569',
            itemsPerRow:        7,
        },
    };

    const loadedFonts = new Set();
    function loadFont(url) {
        if (loadedFonts.has(url)) return;
        loadedFonts.add(url);
        const link = document.createElement('link');
        link.rel  = 'stylesheet';
        link.href = url;
        document.head.appendChild(link);
    }

    function parseItems(raw) {
        const items = [];
        for (const rawLine of raw.split('\n')) {
            const line = rawLine.trim();
            if (!line.startsWith('@')) continue;
            function extract(attr) {
                const marker = '@' + attr + '="';
                const start  = line.indexOf(marker);
                if (start === -1) return '';
                const vs = start + marker.length;
                const end = line.indexOf('"', vs);
                return end === -1 ? '' : line.slice(vs, end);
            }
            const name = extract('name');
            if (!name) continue;
            items.push({
                name:      name,
                img:       extract('item'),
                url:       extract('img'),
                quantity:  extract('quantity'),
                lore:      extract('lore').replace(/\\n/g, '\n'),
                desc:      extract('description').replace(/\\n/g, '\n'),
                enchanted: line.includes('@enchanted'),
            });
        }
        return items;
    }

    function buildCrateHTML(crateName) {
        const crate = CRATES[crateName];
        if (!crate) return null;

        const t = THEMES[crate.theme] || THEMES.sleek;
        loadFont(t.fontUrl);

        const bgPanel      = crate.colorBgPanel      || t.panelBg;
        const bgCell       = crate.colorBgCell       || t.cellBg;
        const bgCellHover  = crate.colorBgCellHover  || t.cellHoverBg;
        const bgTooltip    = crate.colorBgTooltip    || t.tooltipBg;
        const textTooltip  = crate.colorTextTooltip  || t.tooltipText;
        const textCount    = crate.colorTextCount    || t.countColor;

        const borderCell       = crate.colorBorderCell ? '1px solid ' + crate.colorBorderCell : null;
        const cellBorderTop    = borderCell || t.cellBorderTop;
        const cellBorderLeft   = borderCell || t.cellBorderLeft;
        const cellBorderRight  = borderCell || t.cellBorderRight;
        const cellBorderBottom = borderCell || t.cellBorderBottom;
        const tooltipBorder    = crate.colorBorderTooltip ? '1px solid ' + crate.colorBorderTooltip : t.tooltipBorder;
        const tooltipArrow     = crate.colorBorderTooltip || t.tooltipArrow;

        const items   = parseItems(crate.items);
        const cols    = t.itemsPerRow;
        const numRows = Math.ceil(items.length / cols);
        const API     = 'https://api.minecraftitems.xyz/api/item/';

        const cellStyle = (bg) => `
            width:${t.cellSize};height:${t.cellSize};
            background:${bg};
            border-top:${cellBorderTop};border-left:${cellBorderLeft};
            border-right:${cellBorderRight};border-bottom:${cellBorderBottom};
            border-radius:${t.cellRadius};
            box-sizing:border-box;display:flex;
            align-items:center;justify-content:center;
            position:relative;cursor:default;
        `;

        function emptyCell() {
            const img = crate.emptySlot
                ? `<img class="inv-item-img empty-slot-img" src="${API}${crate.emptySlot}" alt="" style="width:${t.imgSize};height:${t.imgSize};">`
                : '';
            return `<div style="${cellStyle(bgCell)}">${img}</div>`;
        }

        function itemCell(item) {
            const glint  = item.enchanted ? '?glint=true' : '';
            const imgSrc = item.url ? item.url + glint : API + item.img + glint;

            const count = parseInt(item.quantity, 10) > 1
                ? `<span style="position:absolute;bottom:2px;right:3px;font-size:${t.countSize};font-weight:${t.countWeight};color:${textCount};text-shadow:${t.countShadow};font-family:${t.fontFamily};line-height:1;pointer-events:none;">${item.quantity}</span>`
                : '';

            const lore = item.lore
                ? `<span style="display:block;white-space:pre;font-style:italic;color:${t.tooltipLoreColor};font-size:0.9em;margin-top:4px;">${item.lore}</span>`
                : '';

            const desc = item.desc
                ? `<span style="display:block;white-space:pre;color:${t.tooltipDescColor};font-size:0.85em;margin-top:5px;border-top:1px solid ${tooltipArrow};padding-top:5px;">${item.desc}</span>`
                : '';

            const tooltip = `
                <div class="inv-tooltip" style="
                    background:${bgTooltip};border:${tooltipBorder};
                    font-size:${t.tooltipSize};font-family:${t.fontFamily};
                    font-weight:${t.tooltipWeight};padding:${t.tooltipPadding};
                    box-shadow:${t.tooltipShadow};border-radius:${t.tooltipRadius};
                    letter-spacing:${t.tooltipTracking};text-shadow:${t.tooltipTextShadow};
                ">
                    <span style="display:block;color:${textTooltip};font-weight:${t.tooltipWeight};">${item.name}</span>
                    ${lore}${desc}
                    <span style="position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:${tooltipArrow};"></span>
                </div>`;

            return `
                <div class="inv-cell item-slot"
                    style="${cellStyle(bgCell)}"
                    onmouseenter="this.style.background='${bgCellHover}';this.style.transform='${t.cellHoverTransform}';this.style.boxShadow='${t.cellHoverShadow}';"
                    onmouseleave="this.style.background='${bgCell}';this.style.transform='none';this.style.boxShadow='none';"
                >
                    <img class="inv-item-img" src="${imgSrc}" alt="${item.name}" style="width:${t.imgSize};height:${t.imgSize};">
                    ${count}
                    ${tooltip}
                </div>`;
        }

        const rowStyle = `display:flex;gap:${t.cellGap};`;
        let rows = '';

        // Top blank row
        let top = '';
        for (let i = 0; i < cols + 2; i++) top += emptyCell();
        rows += `<div style="${rowStyle}">${top}</div>`;

        // Item rows
        for (let r = 0; r < numRows; r++) {
            let row = emptyCell();
            for (let c = 0; c < cols; c++) {
                const item = items[r * cols + c];
                row += item ? itemCell(item) : emptyCell();
            }
            row += emptyCell();
            rows += `<div style="${rowStyle}">${row}</div>`;
        }

        // Bottom blank row
        let bottom = '';
        for (let i = 0; i < cols + 2; i++) bottom += emptyCell();
        rows += `<div style="${rowStyle}">${bottom}</div>`;

        return `
            <div style="
                display:inline-block;
                background:${bgPanel};
                border-top:${t.panelBorderTop};border-left:${t.panelBorderLeft};
                border-right:${t.panelBorderRight};border-bottom:${t.panelBorderBottom};
                padding:${t.panelPadding};box-shadow:${t.panelShadow};
                border-radius:${t.panelRadius};font-family:${t.fontFamily};
            ">
                <div style="display:flex;flex-direction:column;gap:${t.cellGap};">
                    ${rows}
                </div>
            </div>`;
    }

    function replacePlaceholders(root) {
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
        const hits   = [];
        let node;
        while ((node = walker.nextNode())) {
            if (node.nodeValue.includes('@crate-preview-builder:')) hits.push(node);
        }

        for (const textNode of hits) {
            const parts = textNode.nodeValue.split(/(@crate-preview-builder:[\w-]+)/g);
            const frag  = document.createDocumentFragment();
            for (const part of parts) {
                const match = part.match(/^@crate-preview-builder:([\w-]+)$/);
                if (match) {
                    const html = buildCrateHTML(match[1]);
                    if (html) {
                        const wrapper = document.createElement('span');
                        wrapper.setAttribute('data-crate-preview', match[1]);
                        wrapper.innerHTML = html;
                        frag.appendChild(wrapper);
                    } else {
                        frag.appendChild(document.createTextNode(part));
                    }
                } else if (part) {
                    frag.appendChild(document.createTextNode(part));
                }
            }
            textNode.parentNode.replaceChild(frag, textNode);
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        replacePlaceholders(document.body);
    });

})();
</script>
