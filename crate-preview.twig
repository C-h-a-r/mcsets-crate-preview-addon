{# ============================================================ #}
{#                          STYLES                              #}
{# ============================================================ #}

<style>
    .crate-preview-outer {
        display: block;
        width: 100%;
        box-sizing: border-box;
    }

    .crate-inv-panel {
        display: block;
        width: 100%;
        box-sizing: border-box;
    }

    .crate-inv-grid {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    .crate-inv-row {
        display: flex;
        flex-direction: row;
        width: 100%;
    }

    .crate-inv-cell {
        flex: 1 1 0;
        min-width: 0;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: visible;
        /* aspect-ratio keeps cells square */
        aspect-ratio: 1 / 1;
    }

    .crate-inv-cell.item-slot {
        cursor: pointer;
    }

    .crate-inv-cell.item-slot:hover .crate-inv-tooltip {
        display: block !important;
    }

    .crate-inv-img {
        image-rendering: pixelated;
        display: block;
        pointer-events: none;
        /* image fills a ratio of the cell — set via inline style */
    }

    .crate-inv-img.empty {
        opacity: 0.3;
    }

    .crate-inv-count {
        position: absolute;
        bottom: 4%;
        right: 5%;
        line-height: 1;
        pointer-events: none;
    }

    .crate-inv-tooltip {
        display: none;
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        z-index: 9999;
        pointer-events: none;
        min-width: 100px;
    }

    .crate-inv-tooltip-arrow {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
    }
</style>


{# ============================================================ #}
{#                     SERIALISE TO JS                          #}
{# ============================================================ #}

<script>
(function () {

    const THEMES = {
        {% for name, t in themes %}
        {{ name }}: {
            fontUrl:            {{ t.font_url|json_encode|raw }},
            fontFamily:         {{ t.font_family|json_encode|raw }},
            panelBg:            {{ t.panel_bg|json_encode|raw }},
            panelPadding:       {{ t.panel_padding|json_encode|raw }},
            panelRadius:        {{ t.panel_radius|json_encode|raw }},
            panelShadow:        {{ t.panel_shadow|json_encode|raw }},
            panelBorderTop:     {{ t.panel_border_top|json_encode|raw }},
            panelBorderLeft:    {{ t.panel_border_left|json_encode|raw }},
            panelBorderRight:   {{ t.panel_border_right|json_encode|raw }},
            panelBorderBottom:  {{ t.panel_border_bottom|json_encode|raw }},
            cellSize:           {{ t.cell_size|json_encode|raw }},
            cellGap:            {{ t.cell_gap|json_encode|raw }},
            cellBg:             {{ t.cell_bg|json_encode|raw }},
            cellHoverBg:        {{ t.cell_hover_bg|json_encode|raw }},
            cellHoverTransform: {{ t.cell_hover_transform|json_encode|raw }},
            cellHoverShadow:    {{ t.cell_hover_shadow|json_encode|raw }},
            cellRadius:         {{ t.cell_radius|json_encode|raw }},
            cellBorderTop:      {{ t.cell_border_top|json_encode|raw }},
            cellBorderLeft:     {{ t.cell_border_left|json_encode|raw }},
            cellBorderRight:    {{ t.cell_border_right|json_encode|raw }},
            cellBorderBottom:   {{ t.cell_border_bottom|json_encode|raw }},
            imgSize:            {{ t.img_size|json_encode|raw }},
            imgSizeRatio:       {{ t.img_size_ratio|json_encode|raw }},
            countSize:          {{ t.count_size|json_encode|raw }},
            countWeight:        {{ t.count_weight|json_encode|raw }},
            countColor:         {{ t.count_color|json_encode|raw }},
            countShadow:        {{ t.count_shadow|json_encode|raw }},
            tooltipBg:          {{ t.tooltip_bg|json_encode|raw }},
            tooltipBorderWidth: {{ t.tooltip_border_width|json_encode|raw }},
            tooltipBorderStyle: {{ t.tooltip_border_style|json_encode|raw }},
            tooltipBorderColor: {{ t.tooltip_border_color|json_encode|raw }},
            tooltipRadius:      {{ t.tooltip_radius|json_encode|raw }},
            tooltipPadding:     {{ t.tooltip_padding|json_encode|raw }},
            tooltipShadow:      {{ t.tooltip_shadow|json_encode|raw }},
            tooltipText:        {{ t.tooltip_text|json_encode|raw }},
            tooltipLoreColor:   {{ t.tooltip_lore_color|json_encode|raw }},
            tooltipDescColor:   {{ t.tooltip_desc_color|json_encode|raw }},
            tooltipSize:        {{ t.tooltip_size|json_encode|raw }},
            tooltipWeight:      {{ t.tooltip_weight|json_encode|raw }},
            tooltipTextShadow:  {{ t.tooltip_text_shadow|json_encode|raw }},
            tooltipTracking:    {{ t.tooltip_tracking|json_encode|raw }},
            itemsPerRow:        {{ t.items_per_row }},
        },
        {% endfor %}
    };

    const CRATES = {
        {% for name, c in crates %}
        {{ name }}: {
            theme:                      {{ c.theme|json_encode|raw }},
            emptySlot:                  {{ c.empty_slot ? c.empty_slot|json_encode|raw : 'null' }},
            colorBgPanel:               {{ c.color_bg_panel ? c.color_bg_panel|json_encode|raw : 'null' }},
            colorBgCell:                {{ c.color_bg_cell ? c.color_bg_cell|json_encode|raw : 'null' }},
            colorBgCellHover:           {{ c.color_bg_cell_hover ? c.color_bg_cell_hover|json_encode|raw : 'null' }},
            colorBgTooltip:             {{ c.color_bg_tooltip ? c.color_bg_tooltip|json_encode|raw : 'null' }},
            colorTextTooltip:           {{ c.color_text_tooltip ? c.color_text_tooltip|json_encode|raw : 'null' }},
            colorBorderCell:            {{ c.color_border_cell ? c.color_border_cell|json_encode|raw : 'null' }},
            colorBorderTooltip:         {{ c.color_border_tooltip ? c.color_border_tooltip|json_encode|raw : 'null' }},
            colorTextCount:             {{ c.color_text_count ? c.color_text_count|json_encode|raw : 'null' }},
            overrideCellSize:           {{ c.override_cell_size is defined and c.override_cell_size ? c.override_cell_size|json_encode|raw : 'null' }},
            overrideCellGap:            {{ c.override_cell_gap is defined and c.override_cell_gap ? c.override_cell_gap|json_encode|raw : 'null' }},
            overrideCellRadius:         {{ c.override_cell_radius is defined and c.override_cell_radius ? c.override_cell_radius|json_encode|raw : 'null' }},
            overrideCellBorderWidth:    {{ c.override_cell_border_width is defined and c.override_cell_border_width ? c.override_cell_border_width|json_encode|raw : 'null' }},
            overridePanelRadius:        {{ c.override_panel_radius is defined and c.override_panel_radius ? c.override_panel_radius|json_encode|raw : 'null' }},
            overridePanelPadding:       {{ c.override_panel_padding is defined and c.override_panel_padding ? c.override_panel_padding|json_encode|raw : 'null' }},
            overrideImgSizeRatio:       {{ c.override_img_size_ratio is defined and c.override_img_size_ratio ? c.override_img_size_ratio|json_encode|raw : 'null' }},
            overrideTooltipRadius:      {{ c.override_tooltip_radius is defined and c.override_tooltip_radius ? c.override_tooltip_radius|json_encode|raw : 'null' }},
            overrideTooltipBorderWidth: {{ c.override_tooltip_border_width is defined and c.override_tooltip_border_width ? c.override_tooltip_border_width|json_encode|raw : 'null' }},
            overrideItemsPerRow:        {{ c.override_items_per_row is defined and c.override_items_per_row ? c.override_items_per_row : 'null' }},
            items:                      {{ c.items|json_encode|raw }},
        },
        {% endfor %}
    };

    const loadedFonts = new Set();
    function loadFont(url) {
        if (loadedFonts.has(url)) return;
        loadedFonts.add(url);
        const link = document.createElement('link');
        link.rel   = 'stylesheet';
        link.href  = url;
        document.head.appendChild(link);
    }

    function parseItems(raw) {
        const items = [];
        for (const rawLine of raw.split('\n')) {
            const line = rawLine.trim();
            if (!line.startsWith('@')) continue;
            function extract(attr) {
                const marker = '@' + attr + '="';
                const start  = line.indexOf(marker);
                if (start === -1) return '';
                const vs  = start + marker.length;
                const end = line.indexOf('"', vs);
                return end === -1 ? '' : line.slice(vs, end);
            }
            const name = extract('name');
            if (!name) continue;
            items.push({
                name:      name,
                img:       extract('item'),
                url:       extract('img'),
                quantity:  extract('quantity'),
                lore:      extract('lore').replace(/\\n/g, '\n'),
                desc:      extract('description').replace(/\\n/g, '\n'),
                enchanted: line.includes('@enchanted'),
            });
        }
        return items;
    }

    function resolveConfig(crate) {
        const base = Object.assign({}, THEMES[crate.theme] || THEMES.sleek);

        if (crate.colorBgPanel)        base.panelBg            = crate.colorBgPanel;
        if (crate.colorBgCell)         base.cellBg             = crate.colorBgCell;
        if (crate.colorBgCellHover)    base.cellHoverBg        = crate.colorBgCellHover;
        if (crate.colorBgTooltip)      base.tooltipBg          = crate.colorBgTooltip;
        if (crate.colorTextTooltip)    base.tooltipText        = crate.colorTextTooltip;
        if (crate.colorTextCount)      base.countColor         = crate.colorTextCount;
        if (crate.colorBorderTooltip)  base.tooltipBorderColor = crate.colorBorderTooltip;

        if (crate.colorBorderCell) {
            const b = crate.colorBorderCell;
            const w = crate.overrideCellBorderWidth || '1px';
            base.cellBorderTop    = `${w} solid ${b}`;
            base.cellBorderLeft   = `${w} solid ${b}`;
            base.cellBorderRight  = `${w} solid ${b}`;
            base.cellBorderBottom = `${w} solid ${b}`;
        }

        if (crate.overrideCellSize)      base.cellSize      = crate.overrideCellSize;
        if (crate.overrideCellGap)       base.cellGap       = crate.overrideCellGap;
        if (crate.overrideCellRadius)    base.cellRadius    = crate.overrideCellRadius;
        if (crate.overridePanelRadius)   base.panelRadius   = crate.overridePanelRadius;
        if (crate.overridePanelPadding)  base.panelPadding  = crate.overridePanelPadding;
        if (crate.overrideImgSizeRatio)  base.imgSizeRatio  = crate.overrideImgSizeRatio;
        if (crate.overrideTooltipRadius) base.tooltipRadius = crate.overrideTooltipRadius;
        if (crate.overrideItemsPerRow)   base.itemsPerRow   = crate.overrideItemsPerRow;

        if (crate.overrideCellBorderWidth) {
            const w  = crate.overrideCellBorderWidth;
            const rb = (v) => v.replace(/^\d+(\.\d+)?px/, w);
            base.cellBorderTop    = rb(base.cellBorderTop);
            base.cellBorderLeft   = rb(base.cellBorderLeft);
            base.cellBorderRight  = rb(base.cellBorderRight);
            base.cellBorderBottom = rb(base.cellBorderBottom);
        }

        if (crate.overrideTooltipBorderWidth) base.tooltipBorderWidth = crate.overrideTooltipBorderWidth;

        base.tooltipBorder = `${base.tooltipBorderWidth} ${base.tooltipBorderStyle} ${base.tooltipBorderColor}`;

        return base;
    }

    function buildCrateHTML(crateName) {
        const crate = CRATES[crateName];
        if (!crate) return null;

        const t           = resolveConfig(crate);
        const API         = 'https://api.minecraftitems.xyz/api/item/';
        const items       = parseItems(crate.items);
        const cols        = t.itemsPerRow;
        const numRows     = Math.ceil(items.length / cols);
        const totalCols   = cols + 2;
        const imgRatio    = parseFloat(t.imgSizeRatio) || 0.7;

        // Gap expressed as a percentage of cell width for the flex layout.
        // We use CSS gap on the grid rows/columns using a vw-like calc below,
        // but since we can't know cell width at build time we use a ratio.
        // Instead, gap is expressed as a fraction of cell size:
        // cellGapRatio = gap / cellSize (from theme defaults, used for proportional gap)
        const defaultCellPx = parseFloat(t.cellSize) || 44;
        const defaultGapPx  = parseFloat(t.cellGap)  || 6;
        const gapRatio      = defaultGapPx / defaultCellPx; // e.g. 6/44 ≈ 0.136

        loadFont(t.fontUrl);

        function cellStyle(bg, extra) {
            return [
                `background:${bg}`,
                `border-top:${t.cellBorderTop}`,
                `border-left:${t.cellBorderLeft}`,
                `border-right:${t.cellBorderRight}`,
                `border-bottom:${t.cellBorderBottom}`,
                `border-radius:${t.cellRadius}`,
                `box-sizing:border-box`,
                `position:relative`,
                `overflow:visible`,
                extra || '',
            ].join(';');
        }

        function emptyCell() {
            const img = crate.emptySlot
                ? `<img class="crate-inv-img empty" src="${API}${crate.emptySlot}" alt="" style="width:${imgRatio * 100}%;height:${imgRatio * 100}%;object-fit:contain;">`
                : '';
            return `<div class="crate-inv-cell" style="${cellStyle(t.cellBg)}">${img}</div>`;
        }

        function itemCell(item) {
            const glint  = item.enchanted ? '?glint=true' : '';
            const imgSrc = item.url ? item.url + glint : API + item.img + glint;

            const count = parseInt(item.quantity, 10) > 1
                ? `<span class="crate-inv-count" style="font-size:0.3em;font-weight:${t.countWeight};color:${t.countColor};text-shadow:${t.countShadow};font-family:${t.fontFamily};">${item.quantity}</span>`
                : '';

            const lore = item.lore
                ? `<span style="display:block;white-space:pre;font-style:italic;color:${t.tooltipLoreColor};font-size:0.9em;margin-top:4px;">${item.lore}</span>`
                : '';

            const desc = item.desc
                ? `<span style="display:block;white-space:pre;color:${t.tooltipDescColor};font-size:0.85em;margin-top:5px;border-top:1px solid ${t.tooltipBorderColor};padding-top:5px;">${item.desc}</span>`
                : '';

            const tooltip = `
                <div class="crate-inv-tooltip" style="
                    background:${t.tooltipBg};
                    border:${t.tooltipBorder};
                    font-size:${t.tooltipSize};
                    font-family:${t.fontFamily};
                    font-weight:${t.tooltipWeight};
                    padding:${t.tooltipPadding};
                    box-shadow:${t.tooltipShadow};
                    border-radius:${t.tooltipRadius};
                    letter-spacing:${t.tooltipTracking};
                    text-shadow:${t.tooltipTextShadow};
                ">
                    <span style="display:block;color:${t.tooltipText};font-weight:${t.tooltipWeight};">${item.name}</span>
                    ${lore}${desc}
                    <span class="crate-inv-tooltip-arrow" style="border-top-color:${t.tooltipBorderColor};"></span>
                </div>`;

            return `
                <div class="crate-inv-cell item-slot"
                    style="${cellStyle(t.cellBg, 'cursor:pointer;transition:background 0.15s,transform 0.15s,box-shadow 0.15s;')}"
                    onmouseenter="this.style.background='${t.cellHoverBg}';this.style.transform='${t.cellHoverTransform}';this.style.boxShadow='${t.cellHoverShadow}';"
                    onmouseleave="this.style.background='${t.cellBg}';this.style.transform='none';this.style.boxShadow='none';"
                >
                    <img class="crate-inv-img" src="${imgSrc}" alt="${item.name}" style="width:${imgRatio * 100}%;height:${imgRatio * 100}%;object-fit:contain;">
                    ${count}
                    ${tooltip}
                </div>`;
        }

        // Gap between cells expressed as a percentage-based CSS calc.
        // We want: gap = gapRatio * cellWidth, but cellWidth = (100% - gaps) / totalCols.
        // This is tricky in pure CSS so we use a small gap % of the row width instead.
        // gap% = gapRatio / (1 + gapRatio * totalCols) * 100  (approximate)
        const gapPct = (gapRatio / (totalCols + gapRatio * (totalCols - 1)) * 100).toFixed(3);

        const rowStyle = `display:flex;flex-direction:row;width:100%;gap:${gapPct}%;box-sizing:border-box;`;
        let rows = '';

        let topRow = '';
        for (let i = 0; i < totalCols; i++) topRow += emptyCell();
        rows += `<div class="crate-inv-row" style="${rowStyle}margin-bottom:${gapPct}%;">${topRow}</div>`;

        for (let r = 0; r < numRows; r++) {
            let row = emptyCell();
            for (let c = 0; c < cols; c++) {
                const item = items[r * cols + c];
                row += item ? itemCell(item) : emptyCell();
            }
            row += emptyCell();
            const isLast = r === numRows - 1;
            rows += `<div class="crate-inv-row" style="${rowStyle}${!isLast ? `margin-bottom:${gapPct}%;` : ''}">${row}</div>`;
        }

        let bottomRow = '';
        for (let i = 0; i < totalCols; i++) bottomRow += emptyCell();
        rows += `<div class="crate-inv-row" style="${rowStyle}margin-top:${gapPct}%;">${bottomRow}</div>`;

        return `
            <div class="crate-preview-outer">
                <div class="crate-inv-panel" style="
                    display:block;
                    width:100%;
                    box-sizing:border-box;
                    background:${t.panelBg};
                    border-top:${t.panelBorderTop};
                    border-left:${t.panelBorderLeft};
                    border-right:${t.panelBorderRight};
                    border-bottom:${t.panelBorderBottom};
                    padding:${t.panelPadding};
                    box-shadow:${t.panelShadow};
                    border-radius:${t.panelRadius};
                    font-family:${t.fontFamily};
                ">
                    <div class="crate-inv-grid" style="display:flex;flex-direction:column;width:100%;box-sizing:border-box;">
                        ${rows}
                    </div>
                </div>
            </div>`;
    }

    function replacePlaceholders(root) {
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
        const hits   = [];
        let node;
        while ((node = walker.nextNode())) {
            if (node.nodeValue.includes('@crate-preview-builder:')) hits.push(node);
        }
        for (const textNode of hits) {
            const parts = textNode.nodeValue.split(/(@crate-preview-builder:[\w-]+)/g);
            const frag  = document.createDocumentFragment();
            for (const part of parts) {
                const match = part.match(/^@crate-preview-builder:([\w-]+)$/);
                if (match) {
                    const html = buildCrateHTML(match[1]);
                    if (html) {
                        const wrapper = document.createElement('div');
                        wrapper.style.display = 'block';
                        wrapper.style.width   = '100%';
                        wrapper.setAttribute('data-crate-preview', match[1]);
                        wrapper.innerHTML = html;
                        frag.appendChild(wrapper);
                    } else {
                        frag.appendChild(document.createTextNode(part));
                    }
                } else if (part) {
                    frag.appendChild(document.createTextNode(part));
                }
            }
            textNode.parentNode.replaceChild(frag, textNode);
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        replacePlaceholders(document.body);
    });

})();
</script>
